                <label for="pq_ncuota">N° Cuota</label>
                <input type="number" id="pq_ncuota" min="1" required readonly>
            </div>
            
            <div class="form-group">
                <label for="pq_fecha">Fecha de Pago</label>
                <input type="date" id="pq_fecha" required>
            </div>
            
