                <label for="ac_parcela">N° de Parcela/Unidad</label>
                <input type="text" id="ac_parcela" readonly>
            </div>
            
            <div class="form-group">
                <label for="ac_deuda">Deuda Original ($)</label>
                <input type="number" id="ac_deuda" min="1" step="1" required>
            </div>
            
            <div class="form-group">
                <label for="ac_cuotas">N° de Cuotas</label>
                <input type="number" id="ac_cuotas" min="1" step="1" required>
            </div>
            
            <div class="form-group">
                <label for="ac_valor">Valor por Cuota ($)</label>
                <input type="number" id="ac_valor" min="1" step="1" required>
            </div>
            
            <div class="form-group">
                <label for="ac_fecha">Fecha Inicio</label>
                <input type="date" id="ac_fecha" required>
            </div>
            
