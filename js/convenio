                <label for="ac_interes">Interés (%)</label>
                <input type="number" id="ac_interes" min="0" step="0.01" value="0">
            </div>
            
            <div class="form-actions">
                <button class="btn btn-danger" id="ac_cerrar">Cancelar</button>
                <button class="btn btn-success" id="ac_guardar">Activar Convenio</button>
            </div>
        </div>
    </div>
    
    <!-- Modal para Registrar Pago -->
    <div id="modal-pago" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Registrar Pago de Cuota</h2>
                <span class="close">&times;</span>
            </div>
            
            <div class="notification success" id="pago-success-msg" style="display: none;">
                Pago registrado exitosamente!
            </div>
            
