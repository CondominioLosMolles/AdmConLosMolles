    <script>
        // Simulación de datos - En un caso real, estos vendrían de Google Sheets
        let conveniosData = {
            "105": {
                deudaOriginal: 850000,
                saldoConvenio: 350000,
                nCuotas: 10,
                valorCuota: 85000,
                cuotas: [
                    { nCuota: 1, fechaVencimiento: "2025-01-10", montoCuota: 85000, pagadoAcumulado: 85000, saldoCuota: 0, estado: "Pagada", comprobantes: "comprobante_1.pdf" },
                    { nCuota: 2, fechaVencimiento: "2025-02-10", montoCuota: 85000, pagadoAcumulado: 85000, saldoCuota: 0, estado: "Pagada", comprobantes: "comprobante_2.pdf" },
                    { nCuota: 3, fechaVencimiento: "2025-03-10", montoCuota: 85000, pagadoAcumulado: 85000, saldoCuota: 0, estado: "Pagada", comprobantes: "comprobante_3.pdf" },
                    { nCuota: 4, fechaVencimiento: "2025-04-10", montoCuota: 85000, pagadoAcumulado: 85000, saldoCuota: 0, estado: "Pagada", comprobantes: "comprobante_4.pdf" },
                    { nCuota: 5, fechaVencimiento: "2025-05-10", montoCuota: 85000, pagadoAcumulado: 85000, saldoCuota: 0, estado: "Pagada", comprobantes: "comprobante_5.pdf" },
                    { nCuota: 6, fechaVencimiento: "2025-06-10", montoCuota: 85000, pagadoAcumulado: 50000, saldoCuota: 35000, estado: "Parcial", comprobantes: "comprobante_6.pdf" },
                    { nCuota: 7, fechaVencimiento: "2025-07-10", montoCuota: 85000, pagadoAcumulado: 0, saldoCuota: 85000, estado: "Pendiente", comprobantes: "" },
                    { nCuota: 8, fechaVencimiento: "2025-08-10", montoCuota: 85000, pagadoAcumulado: 0, saldoCuota: 85000, estado: "Pendiente", comprobantes: "" },
                    { nCuota: 9, fechaVencimiento: "2025-09-10", montoCuota: 85000, pagadoAcumulado: 0, saldoCuota: 85000, estado: "Pendiente", comprobantes: "" },
                    { nCuota: 10, fechaVencimiento: "2025-10-10", montoCuota: 85000, pagadoAcumulado: 0, saldoCuota: 85000, estado: "Pendiente", comprobantes: "" }
                ]
            }
        };

        document.addEventListener('DOMContentLoaded', function() {
            // Configurar fecha actual por defecto
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('ac_fecha').value = today;
            document.getElementById('pq_fecha').value = today;
            
            // Obtener elementos DOM
            const modalConvenio = document.getElementById('modal-convenio');
            const modalPago = document.getElementById('modal-pago');
            const btnBuscar = document.getElementById('btn-buscar-convenio');
            const btnActivar = document.getElementById('btn-activar-convenio');
            const btnCrear = document.getElementById('btn-crear-convenio');
            const btnGuardarConvenio = document.getElementById('ac_guardar');
            const btnCerrarConvenio = document.getElementById('ac_cerrar');
            const btnGuardarPago = document.getElementById('pq_guardar');
            const btnCerrarPago = document.getElementById('pq_cerrar');
            const closeButtons = document.querySelectorAll('.close');
            const parcelaInput = document.getElementById('parcela');
            
            // Event Listeners
            btnBuscar.addEventListener('click', buscarConvenio);
            btnActivar.addEventListener('click', abrirModalConvenio);
            btnCrear.addEventListener('click', abrirModalConvenio);
            btnGuardarConvenio.addEventListener('click', guardarConvenio);
            btnCerrarConvenio.addEventListener('click', cerrarModalConvenio);
            btnGuardarPago.addEventListener('click', registrarPago);
            btnCerrarPago.addEventListener('click', cerrarModalPago);
            
            closeButtons.forEach(button => {
                button.addEventListener('click', function() {
                    modalConvenio.style.display = 'none';
                    modalPago.style.display = 'none';
                });
            });
            
            // Cerrar modal al hacer clic fuera del contenido
            window.addEventListener('click', function(event) {
                if (event.target === modalConvenio) {
                    modalConvenio.style.display = 'none';
                }
                if (event.target === modalPago) {
                    modalPago.style.display = 'none';
                }
            });
            
            // Autocompletar parcela en modal de convenio
            parcelaInput.addEventListener('change', function() {
                document.getElementById('ac_parcela').value = this.value;
            });
            
            // Función para buscar convenio
            function buscarConvenio() {
                const parcela = parcelaInput.value.trim();
                const year = document.getElementById('year').value;
                
                if (!parcela) {
                    alert('Por favor ingrese un número de parcela/unidad');
                    return;
                }
                
                // Simular búsqueda de convenio
                if (conveniosData[parcela]) {
                    mostrarConvenio(conveniosData[parcela]);
                } else {
                    document.getElementById('convenio-info').style.display = 'none';
                    document.getElementById('no-convenio').style.display = 'block';
                }
            }
            
            // Función para mostrar convenio
            function mostrarConvenio(convenio) {
                document.getElementById('no-convenio').style.display = 'none';
                
                // Actualizar resumen
                const summaryCards = document.querySelectorAll('.summary-card');
                summaryCards[0].querySelector('.value').textContent = `$${convenio.deudaOriginal.toLocaleString('es-CL')}`;
                summaryCards[1].querySelector('.value').textContent = `$${convenio.saldoConvenio.toLocaleString('es-CL')}`;
                
                const cuotasPagadas = convenio.cuotas.filter(c => c.estado === 'Pagada').length;
                summaryCards[2].querySelector('.value').textContent = `${cuotasPagadas}/${convenio.nCuotas}`;
                summaryCards[3].querySelector('.value').textContent = `$${convenio.valorCuota.toLocaleString('es-CL')}`;
                
                // Actualizar tabla
                const tbody = document.querySelector('#convenio-info tbody');
                tbody.innerHTML = '';
                
                convenio.cuotas.forEach(cuota => {
                    const tr = document.createElement('tr');
                    
                    const statusClass = cuota.estado === 'Pagada' ? 'status-paid' : 
                                      cuota.estado === 'Parcial' ? 'status-partial' : 'status-pending';
                    const statusText = cuota.estado === 'Pagada' ? 'Pagada' : 
                                     cuota.estado === 'Parcial' ? 'Parcial' : 'Pendiente';
                    
                    const comprobanteHTML = cuota.comprobantes ? 
                        `<a href="#" target="_blank">${cuota.comprobantes}</a>` : 
                        '-';
                    
                    const actionButton = cuota.estado === 'Pagada' ?
                        `<button class="btn btn-primary" disabled>Pagada</button>` :
                        `<button class="btn btn-primary" onclick="abrirModalPago(${cuota.nCuota})">Pagar</button>`;
                    
                    tr.innerHTML = `
                        <td>${cuota.nCuota}</td>
                        <td>${formatDate(cuota.fechaVencimiento)}</td>
                        <td>$${cuota.montoCuota.toLocaleString('es-CL')}</td>
                        <td>$${cuota.pagadoAcumulado.toLocaleString('es-CL')}</td>
                        <td>$${cuota.saldoCuota.toLocaleString('es-CL')}</td>
                        <td><span class="status ${statusClass}">${statusText}</span></td>
                        <td class="comprobante">${comprobanteHTML}</td>
                        <td>${actionButton}</td>
                    `;
                    
                    tbody.appendChild(tr);
                });
                
                document.getElementById('convenio-info').style.display = 'block';
            }
            
            // Función para abrir modal de convenio
            function abrirModalConvenio() {
                const parcela = parcelaInput.value.trim();
                if (parcela) {
                    document.getElementById('ac_parcela').value = parcela;
                }
                document.getElementById('success-msg').style.display = 'none';
                document.getElementById('error-msg').style.display = 'none';
                modalConvenio.style.display = 'flex';
            }
            
            // Función para cerrar modal de convenio
            function cerrarModalConvenio() {
                modalConvenio.style.display = 'none';
            }
            
            // Función para guardar convenio
            function guardarConvenio() {
                const parcela = document.getElementById('ac_parcela').value;
                const deuda = document.getElementById('ac_deuda').value;
                const cuotas = document.getElementById('ac_cuotas').value;
                const valor = document.getElementById('ac_valor').value;
                const fecha = document.getElementById('ac_fecha').value;
                
                if (!parcela || !deuda || !cuotas || !valor || !fecha) {
                    document.getElementById('error-msg').style.display = 'block';
                    return;
                }
                
                // Simular guardado exitoso
                document.getElementById('success-msg').style.display = 'block';
                
                // Cerrar modal después de 2 segundos
                setTimeout(() => {
                    modalConvenio.style.display = 'none';
                    // Actualizar la vista con el nuevo convenio
                    buscarConvenio();
                }, 2000);
            }
            
            // Función para abrir modal de pago
            window.abrirModalPago = function(nCuota) {
                document.getElementById('pq_ncuota').value = nCuota;
                document.getElementById('pq_monto').value = conveniosData[parcelaInput.value].valorCuota;
                document.getElementById('pago-success-msg').style.display = 'none';
                modalPago.style.display = 'flex';
            };
            
            // Función para cerrar modal de pago
            function cerrarModalPago() {
                modalPago.style.display = 'none';
            }
            
            // Función para registrar pago
            function registrarPago() {
                const nCuota = document.getElementById('pq_ncuota').value;
                const fecha = document.getElementById('pq_fecha').value;
                const monto = document.getElementById('pq_monto').value;
                const metodo = document.getElementById('pq_metodo').value;
                
                if (!nCuota || !fecha || !monto || !metodo) {
                    alert('Por favor complete todos los campos obligatorios');
                    return;
                }
                
                // Simular registro exitoso
                document.getElementById('pago-success-msg').style.display = 'block';
                
                // Cerrar modal después de 2 segundos
                setTimeout(() => {
                    modalPago.style.display = 'none';
                    // Actualizar la vista con el pago registrado
                    buscarConvenio();
                }, 2000);
            }
            
            // Función auxiliar para formatear fechas
            function formatDate(dateString) {
                const date = new Date(dateString);
                return date.toLocaleDateString('es-CL');
            }
            
            // Simular que ya hay una parcela buscada al cargar la página
            parcelaInput.value = "105";
            buscarConvenio();
        });
    </script>
</body>
</html>
