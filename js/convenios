            const cuotasConvenio = cuotas.filter(cu => cu.ID_Convenio == convenioId).sort((a, b) => a.N_Cuota - b.N_Cuota);
            
            document.getElementById('detalleConvenioTitle').innerText = `Detalle de Cuotas - Parcela ${convenio.N_Parcela} (${convenio.Nombre_Residente})`;
            
            document.getElementById('detalle-convenio-info').innerHTML = `
                <div class="convenio-summary">
                    <div class="row">
                        <div class="col-md-3"><strong>Deuda Original:</strong> $${(convenio.Deuda_Original || 0).toLocaleString('es-CL')}</div>
                        <div class="col-md-3"><strong>Saldo Pendiente:</strong> $${(convenio.Saldo_Convenio || 0).toLocaleString('es-CL')}</div>
                        <div class="col-md-3"><strong>Cuotas Pagadas:</strong> ${cuotasConvenio.filter(c => c.Estado === 'Pagado').length} de ${convenio.N_Cuotas}</div>
                        <div class="col-md-3"><strong>Estado:</strong> <span class="badge bg-${convenio.Estado === 'Activo' ? 'success' : (convenio.Estado === 'Pagado' ? 'info' : 'danger')}">${convenio.Estado}</span></div>
                    </div>
                    ${convenio.Observaciones ? `<div class="mt-2"><strong>Observaciones:</strong> ${convenio.Observaciones}</div>` : ''}
