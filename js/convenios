            document.getElementById('tabla-cuotas-body').innerHTML = cuotasConvenio.map(cuota => `
                <tr>
                    <td>${cuota.N_Cuota}</td>
                    <td>${new Date(cuota.Fecha_Vencimiento).toLocaleDateString('es-CL')}</td>
                    <td>$${(cuota.Monto_Cuota || 0).toLocaleString('es-CL')}</td>
                    <td>$${(cuota.Monto_Pagado || 0).toLocaleString('es-CL')}</td>
                    <td>$${(cuota.Saldo_Cuota || 0).toLocaleString('es-CL')}</td>
                    <td><span class="badge status-badge bg-${cuota.Estado === 'Pagado' ? 'success' : (cuota.Estado === 'Pendiente' ? 'warning' : 'secondary')}">${cuota.Estado}</span></td>
                    <td class="text-center">
                        ${cuota.Estado === 'Pendiente' ? `
                            <button class="btn btn-success btn-sm btn-pagar-cuota" data-id="${cuota.ID_Cuota}">Registrar Pago</button>
                        ` : `
                            <button class="btn btn-outline-info btn-sm btn-ver-pago" data-id="${cuota.ID_Cuota}">Ver Pago</button>
