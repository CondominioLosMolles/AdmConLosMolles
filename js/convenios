                                <i class="fas fa-cloud-upload-alt"></i>
                                <p>Haga clic o arrastre un archivo para subir</p>
                                <input type="file" id="pagoComprobante" class="d-none" accept=".pdf,.jpg,.jpeg,.png">
                                <button type="button" class="btn btn-outline-primary" onclick="document.getElementById('pagoComprobante').click()">
                                    Seleccionar Archivo
                                </button>
                                <div id="nombre-archivo" class="mt-2"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="pagoObservaciones" class="form-label">Observaciones</label>
                            <textarea id="pagoObservaciones" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="form-group text-end mt-3">
                            <button type="button" class="btn btn-secondary me-2" id="btnCancelarPago">Cancelar</button>
                            <button type="submit" class="btn btn-success">Registrar Pago</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Cargar APIs de Google de forma segura -->
    <script>
        // Solución para los errores de variables no definidas
        window.gapiloaded = false;
        window.gisloaded = false;
        
        // Función para cargar scripts de forma segura
        function loadScript(src, onload) {
            return new Promise((resolve, reject) => {
                const script = document.createElement('script');
                script.src = src;
                script.onload = () => {
                    if (onload) onload();
                    resolve();
                };
                script.onerror = reject;
                document.head.appendChild(script);
            });
        }

        // Cargar APIs de Google con manejo de errores
        Promise.all([
            loadScript('https://apis.google.com/js/api.js', () => {
                console.log("Google API cargada correctamente");
                window.gapiloaded = true;
            }),
            loadScript('https://accounts.google.com/gsi/client', () => {
                console.log("Google Identity Services cargado correctamente");
                window.gisloaded = true;
            }),
            loadScript('https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
        ]).then(() => {
            console.log("Todos los scripts cargados correctamente");
            inicializarAplicacion();
        }).catch(error => {
            console.error("Error al cargar scripts:", error);
            mostrarError("Error al cargar recursos necesarios. Por favor, recarga la página.");
        });
    </script>

    <script>
        // Variables globales
        let convenios = [];
        let cuotas = [];
        let residentes = [];
        let currentConvenioId = null;
        let archivoComprobante = null;
        let gapiInicializada = false;

        // Inicializar la aplicación después de cargar los scripts
        function inicializarAplicacion() {
            console.log("Inicializando aplicación...");
            inicializarComponentes();
            inicializarGoogleAPI();
        }

        // Inicializar Google API
        function inicializarGoogleAPI() {
            if (typeof gapi === 'undefined') {
                console.error("gapi no está disponible");
                mostrarError("Error: Google API no se cargó correctamente.");
                return;
            }
            
            console.log("Inicializando gapi client...");
            
            gapi.load('client', {
                callback: function() {
                    console.log("Google API cargada");
                    
                    gapi.client.init({
                        'apiKey': 'TU_API_KEY', // Reemplaza con tu API key
                        'discoveryDocs': ['https://sheets.googleapis.com/$discovery/rest?version=v4', 
                                         'https://drive.googleapis.com/$discovery/rest?version=v3'],
                    }).then(function() {
                        console.log("gapi.client.init() completado.");
                        gapiInicializada = true;
                        cargarConvenios();
                    }).catch(function(error) {
                        console.error("Error al inicializar gapi.client: ", error);
                        mostrarError("Error al inicializar la API de Google: " + error.message);
                    });
                },
                onerror: function() {
                    console.error("Error al cargar la API de Google");
                    mostrarError("Error al cargar la API de Google. Recarga la página.");
                },
                timeout: 10000
            });
        }

        // Inicializar event listeners
        function inicializarComponentes() {
            console.log("Inicializando componentes...");
            
            // Event listeners para modales
            document.getElementById('btnNuevoConvenio').addEventListener('click', abrirModalNuevo);
            document.getElementById('btnCerrarModalNuevo').addEventListener('click', cerrarModalNuevo);
            document.getElementById('btnCerrarModalDetalle').addEventListener('click', cerrarModalDetalle);
            document.getElementById('btnCerrarModalPago').addEventListener('click', cerrarModalPago);
            document.getElementById('btnCancelarConvenio').addEventListener('click', cerrarModalNuevo);
            document.getElementById('btnCancelarPago').addEventListener('click', cerrarModalPago);

            // Event listeners para formularios
            document.getElementById('formNuevoConvenio').addEventListener('submit', guardarConvenio);
            document.getElementById('formPagoCuota').addEventListener('submit', registrarPagoCuota);

            // Event listeners para cálculos
            document.getElementById('convenioDeudaTotal').addEventListener('input', calcularValorCuota);
            document.getElementById('convenioCuotas').addEventListener('input', calcularValorCuota);
            document.getElementById('convenioInteres').addEventListener('input', calcularValorCuota);

            // Event listener para subida de archivos
            document.getElementById('pagoComprobante').addEventListener('change', manejarSubidaArchivo);
            
            console.log("Componentes inicializados correctamente");
        }

        // Cargar datos de convenios
        async function cargarConvenios() {
            if (!gapiInicializada) {
                console.error("Google API no está inicializada");
                mostrarError("Google API no está inicializada. Espera un momento y recarga la página.");
                return;
            }
            
            mostrarSpinnerTabla();
            
            try {
                console.log("Cargando datos de convenios...");
                
                // En un entorno real, aquí se llamaría a la API de Google Sheets
                // const data = await llamarAPI('obtenerDatosConvenios');
                
                // Simulamos datos de prueba
                await simularCargaDatos();
                
                renderizarTablaConvenios();
                console.log("Datos de convenios cargados correctamente");
            } catch (error) {
                mostrarError('Error al cargar datos de convenios: ' + error.message);
                console.error(error);
            } finally {
                ocultarSpinnerTabla();
            }
        }

